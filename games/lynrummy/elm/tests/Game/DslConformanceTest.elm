                        , { boardCards = [ boardCard "7C1", boardCard "7D1", boardCard "7H1" ], loc = { top = 200, left = 300 } }
                        ]

                sourceStack =
                    { boardCards = [ boardCard "AC1", boardCard "AD1", boardCard "AH1" ], loc = { top = 200, left = 100 } }

                result =
                    WingOracle.wingsForStack sourceStack board

            in
            result |> Expect.equal []


