                    want0 =
                        { trickId = "direct_play", handCards = [ parseCard "7H2" ] }

                in
                Expect.all
                    [ \_ -> List.drop 0 got |> List.head |> Maybe.map (\s -> { trickId = s.trickId, handCards = s.handCards }) |> Expect.equal (Just want0)
                    ]
                    ()


