#!/bin/bash
# CANONICAL DEV-LOOP SCRIPT — DO NOT REINVENT.
# Before writing a new ops/* script or composing an ad-hoc
# shell command for build / launch / test / regen, run
# `ops/list` to see what already exists. Drifted ops scripts
# are how an hour disappears resurrecting things.
#
# Compile the LynRummy Elm client (Main.elm) into
# games/lynrummy/elm/elm.js, the JS bundle served by
# /gopher/lynrummy-elm/elm.js. Also bundles the TS engine
# (engine.js) — the Elm client loads it alongside elm.js and
# calls into it via the Hint port.
#
# Failures are warnings, not fatal — the matching HTTP route
# 404s with an actionable error pointing back here.
set -e

source "$(dirname "$0")/_paths.sh"

"$GOPHER_DIR/ops/build_engine_js"

cd "$GOPHER_DIR/games/lynrummy/elm"

if [ ! -x ./node_modules/.bin/elm ]; then
    echo "Warning: ./node_modules/.bin/elm not found — try \`npm install\` in $(pwd)"
    exit 1
fi

./node_modules/.bin/elm make src/Main.elm --output=elm.js >/dev/null 2>&1 \
    || { echo "Warning: Main.elm build failed"; exit 1; }
