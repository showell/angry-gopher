#!/bin/bash
# CANONICAL DEV-LOOP SCRIPT — DO NOT REINVENT.
# Before writing a new ops/* script or composing an ad-hoc
# shell command for build / launch / test / regen, run
# `ops/list` to see what already exists. Drifted ops scripts
# are how an hour disappears resurrecting things.
#
# STANDARD GATE: run after every non-trivial Elm edit, and
# always before reporting a task done. Sub-agents dispatched
# to do Elm work must include this in their completion step.
# The elm-review pass (NoUnused.CustomTypeConstructors et al.)
# catches dead code that elm-test alone misses — skipping it
# is how orphaned type constructors survive undetected.
#
# Two steps:
#   1. TS conformance — runs the engine + leaf primitives + verb
#      fixtures + physical_plan + replay walkthroughs + agent
#      self-play (npm test). All TS tests parse their .dsl
#      inputs directly via per-test or shared TS parsers.
#   2. Elm check.sh — embeds DSLs into Elm via
#      ops/embed_dsls_for_elm.ts, then standalone type-checks,
#      runs elm-test (1000+ — every scenario parsed at test
#      time and dispatched to a hand-written verifier in
#      tests/Game/ConformanceTests.elm), elm make, elm-review.
#
# Exits non-zero on any step's failure.

set -e

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_DIR"

# --skip-slow: omit the two TS suites that are essentially
# engine-workouts — test_engine_conformance.ts and
# test_agent_player.ts. Both stress the BFS solver; both run
# byte-identical when the engine hasn't changed. Skipping them
# during Elm-only iteration is honest. Saves ~70s. Run the full
# gate before commits that touch the engine. Per
# games/lynrummy/README.md ("Gating & testing").
SKIP_SLOW=0
for arg in "$@"; do
    case "$arg" in
        --skip-slow) SKIP_SLOW=1 ;;
        *) echo "Unknown arg: $arg" >&2; exit 2 ;;
    esac
done

# Timing helper — prints elapsed seconds for each phase.
phase() {
    local label="$1"
    shift
    local t0=$SECONDS
    "$@"
    echo "    [phase] ${label}: $((SECONDS - t0))s"
}

echo "==> embed DSLs for Elm"
phase "embed-dsls" ./ops/embed_dsls_for_elm.ts

echo "==> TS typecheck"
phase "ts-typecheck" bash -c "cd games/lynrummy/ts && npm run -s typecheck"

if [ "$SKIP_SLOW" = "1" ]; then
    echo "==> TS conformance (--skip-slow: omitting engine + agent self-play)"
    phase "ts-tests" bash -c "cd games/lynrummy/ts && npm run -s test:skip-slow"
else
    echo "==> TS conformance"
    phase "ts-tests" bash -c "cd games/lynrummy/ts && npm test"
fi

echo "==> Elm conformance"
phase "elm-check" bash -c "cd games/lynrummy/elm && ./check.sh"

echo
echo "Conformance gate passed."
