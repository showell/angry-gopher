#!/bin/bash
# CANONICAL DEV-LOOP SCRIPT — DO NOT REINVENT.
# Before writing a new ops/* script or composing an ad-hoc
# shell command for build / launch / test / regen, run
# `ops/list` to see what already exists. Drifted ops scripts
# are how an hour disappears resurrecting things.
#
# STANDARD GATE: run after every non-trivial Elm edit, and
# always before reporting a task done. Sub-agents dispatched
# to do Elm work must include this in their completion step.
# The elm-review pass (NoUnused.CustomTypeConstructors et al.)
# catches dead code that elm-test alone misses — skipping it
# is how orphaned type constructors survive undetected.
#
# Three steps:
#   1. cmd/fixturegen — DSL → Elm + JSON + ops manifest; also
#      surfaces registered-op manifest drift loudly (per
#      cmd/fixturegen/ADDING_AN_OP.md). Go target retired
#      2026-04-28; Python runner retired 2026-05-02 (TS+Elm
#      now cover the contract).
#   2. TS conformance — runs the engine + leaf primitives
#      against the JSON fixtures (npm test).
#   3. Elm check.sh — standalone type-checks, elm-test (700+),
#      elm make, elm-review.
#
# KNOWN: total wall time ~26s, dominated by Elm compiling the
# generated DslConformanceTest.elm (~277KB). Accepted for now —
# further optimization adds complexity not worth the tradeoff
# at current test count. Revisit if the suite grows substantially.
#
# Exits non-zero on any step's failure.

set -e

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_DIR"

echo "==> fixturegen"
go run ./cmd/fixturegen ./games/lynrummy/conformance/scenarios/*.dsl

echo "==> TS conformance"
(cd games/lynrummy/ts && npm test)

echo "==> Elm conformance"
(cd games/lynrummy/elm && ./check.sh)

echo
echo "Conformance gate passed."
