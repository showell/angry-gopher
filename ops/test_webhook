#!/bin/bash
# Send a simulated GitHub webhook event to the local server.
#
# You must specify a repo ID and an event type:
#   ops/test_webhook 1 push
#   ops/test_webhook 1 pull_request
#   ops/test_webhook 1 issue
set -e

source "$(dirname "$0")/_paths.sh"

if [ $# -lt 2 ]; then
    echo "Usage: ops/test_webhook <repo_id> <event_type>"
    echo ""
    echo "Event types:"
    echo "  push            Simulated push with 2 commits"
    echo "  pull_request    Simulated PR opened"
    echo "  issue           Simulated issue opened"
    echo ""
    echo "Configured repos:"
    cd "$GOPHER_DIR"
    go run ./cmd/db_query -db ~/AngryGopher/prod/gopher.db \
        "SELECT gr.id, gr.owner || '/' || gr.name AS repo, c.name AS channel, gr.default_topic FROM github_repos gr JOIN channels c ON gr.channel_id = c.channel_id" 2>/dev/null
    exit 1
fi

REPO_ID="$1"
EVENT="$2"
URL="http://localhost:9000"

# Look up an admin API key from the database.
cd "$GOPHER_DIR"
API_KEY=$(go run ./cmd/db_query -db ~/AngryGopher/prod/gopher.db \
    "SELECT api_key FROM users WHERE is_admin = 1 LIMIT 1" 2>/dev/null | tail -1)

if [ -z "$API_KEY" ]; then
    echo "Could not find an admin API key in the prod database."
    exit 1
fi

WEBHOOK_URL="${URL}/gopher/webhooks/github?api_key=${API_KEY}&repo_id=${REPO_ID}"

case "$EVENT" in
    push)
        GITHUB_EVENT="push"
        PAYLOAD='{
            "ref": "refs/heads/main",
            "compare": "https://github.com/showell/angry-gopher/compare/abc...def",
            "pusher": {"name": "steve"},
            "repository": {"full_name": "showell/angry-gopher"},
            "commits": [
                {
                    "id": "abc1234567890",
                    "message": "Fix widget rendering in dark mode",
                    "url": "https://github.com/showell/angry-gopher/commit/abc1234"
                },
                {
                    "id": "def5678901234",
                    "message": "Add unit tests for widget",
                    "url": "https://github.com/showell/angry-gopher/commit/def5678"
                }
            ]
        }'
        ;;
    pull_request)
        GITHUB_EVENT="pull_request"
        PAYLOAD='{
            "action": "opened",
            "pull_request": {
                "number": 42,
                "title": "Add GitHub webhook integration",
                "html_url": "https://github.com/showell/angry-gopher/pull/42",
                "user": {"login": "steve"},
                "merged": false
            },
            "repository": {"full_name": "showell/angry-gopher"}
        }'
        ;;
    issue)
        GITHUB_EVENT="issues"
        PAYLOAD='{
            "action": "opened",
            "issue": {
                "number": 7,
                "title": "Webhook messages not rendering links",
                "html_url": "https://github.com/showell/angry-gopher/issues/7",
                "user": {"login": "apoorva"}
            },
            "repository": {"full_name": "showell/angry-gopher"}
        }'
        ;;
    *)
        echo "Unknown event type: $EVENT"
        echo "Valid types: push, pull_request, issue"
        exit 1
        ;;
esac

echo "Sending $GITHUB_EVENT event to repo_id $REPO_ID..."
RESPONSE=$(curl -s -X POST "$WEBHOOK_URL" \
    -H "Content-Type: application/json" \
    -H "X-GitHub-Event: $GITHUB_EVENT" \
    -d "$PAYLOAD")

echo "$RESPONSE" | python3 -m json.tool 2>/dev/null || echo "$RESPONSE"
