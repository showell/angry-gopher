#!/bin/bash
# CANONICAL DEV-LOOP SCRIPT — DO NOT REINVENT.
# Before writing a new ops/* script or composing an ad-hoc shell
# command for build / launch / test / regen, run `ops/list` to see
# what already exists.
#
# THE PRE-COMMIT GATE. Runs the three per-language fast gates
# (~24s warm total). Every check inside is <20s individually. Wired
# to git's pre-commit hook via `ops/install-hooks`.
#
# For the >20s tier (currently test_full_game.ts — agent self-play
# across 6 seeds), use `ops/check_full` instead. Run that before
# pushing changes that touch the BFS engine, the agent loop, or
# the bucket pipeline.

set -e

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_DIR"

t0_total=$SECONDS

echo "===== ops/test_ts ====="
./ops/test_ts

echo
echo "===== ops/test_elm ====="
./ops/test_elm

echo
echo "===== ops/test_go ====="
./ops/test_go

echo
echo "All gates passed in $((SECONDS - t0_total))s."
