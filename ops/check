#!/bin/bash
# Full-repo preflight: regenerate conformance fixtures, run
# every test suite. Addresses the silent-failure risk — if any
# target (Go tests, Elm tests, Python conformance) stops being
# wired up, this script fails loudly instead of silently skipping.
#
# Steve ran this into in the 2026-04-20 rabbit hole: fixturegen's
# Go output path pointed at a deleted directory, and nobody
# noticed for two commits because the generator was never
# re-invoked. Running `ops/check` regularly catches that class
# of severed bridge on the next run.

set -e

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_DIR"

echo "==> sidecar_audit (coverage + broken just_use targets)"
python3 tools/sidecar_audit.py

echo "==> conformance gate (fixturegen + Python + Elm)"
./ops/check-conformance

echo "==> go test ./..."
go test ./...

echo "==> Python unit tests (full suite)"
(cd games/lynrummy/python && ./check.sh)

echo
echo "All preflight checks passed."
