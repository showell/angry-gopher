/gopher-server
/health_check
/stress
/import
/crudgen
/fixturegen
/db_query
/reorg

# Claude Code per-session state (scheduled_tasks.lock, settings.local.json)
/.claude/

# Editor temp files
*.swp

# Python bytecode caches
__pycache__/
*.pyc

# Stray compiled binary from `go build` with no -o (see cmd/ for proper output paths)
/angry-gopher

# LynRummy runtime gameplay artifacts (server creates lazily via MkdirAll)
