study mice
  title: Mice in the Pantry
  desc: Get the mice to the cheese. Watch the trap line.

  # --- VISUAL THEME (the part that really varies) ---

  critters: 🐭 🐁 🐀
  target: cheese                     # target emoji, not a zone
  target_emoji: 🧀                   # sprite shown in target region
  target_color: #f4d47c              # warm cheese-yellow zone fill
  backgrounds: "#f5e9d0" "#e6d3b3" "#d2b48c" "#fff0c8" "#3c2e1d" "#8b6b3a" "#efd9a6"

  # --- MECHANIC + OBSTACLE (same as cows) ---

  mechanic: drag_to_zone
  obstacle: fence                    # reusing fence — "trap line" is just visual
    sides: any
    behavior: soft_snap_back + wobble

  # --- SESSION STRUCTURE (tuned per study) ---

  rounds:
    - name: Tiny Scouts
      boards: 3
      critter_count: 3..6
      already_inside_rate: 0.30
      fence_coverage_pct: 30..50
      target_area_pct: 50..65
    - name: The Full Colony
      boards: 5
      critter_count: 8..15
      already_inside_rate: 0.10
      fence_coverage_pct: 55..80
      target_area_pct: 35..50

  # --- FEEDBACK (framework defaults; same as cows) ---

  feedback:
    on_success: green_ring + pulse
    still_outside_highlight: yellow_ring
    bg_cycle_button: true

  # --- CHROME (identical to cows — framework defaults would cover this) ---

  next_button:
    randomize_position: true
    # omitting positions: framework default palette applies
  quit_button: true
  count_up_clock: top_right

  # --- PRAISE (per-study flavor) ---

  praise_round:
    - "Squeak-tacular!"
    - "All nibbled, all nibbled, none nabbed."
    - "Cheese delivered, mission accomplished."
    - "Pantry raid: flawless."
    - "The pantry mouse council approves."
    - "Tails up, whiskers clean, round done."

  praise_session:
    - "Supreme cheese commander!"
    - "Every mouse, every morsel. Session done."
    - "The cheese board bows to you."
    - "The colony is fed. Goodnight."

  # --- TELEMETRY (framework fields — same as cows) ---

  record:
    drag_paths: true
    click_misses: true
    bg_cycles: true
    wobble_events: true
    reward_entries: true
    board_start: true
    round_complete: true
    session_complete: true

  save_to: /save_recording
  consent: "Mice are hungry. Drag each one to the cheese. Say yes to start."
